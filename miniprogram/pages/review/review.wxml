<!--
  评价页面模板文件 (review.wxml)
  这是订单评价页面，用户完成预订使用后可以对场馆进行评分和评价。
  页面包含：订单基本信息、星级评分选择、评价内容输入框、提交按钮。

  【本页面涉及的重要概念】
  - 星级评分交互：通过点击星星图标来选择评分（1-5分）
  - <textarea>：多行文本输入框，用于输入较长的评价内容
  - wx:for="{{[1,2,3,4,5]}}"：直接遍历一个固定数组，生成5颗星星
  - 动态样式类名：通过条件判断给元素添加不同的样式类
-->

<!-- 页面最外层容器 -->
<view class="container">

  <!-- ==================== 订单基本信息区域 ==================== -->
  <!--
    wx:if="{{order}}"：只有当订单数据存在时才显示
    显示当前评价对应的订单信息，让用户确认是在评价哪个订单
  -->
  <view class="order-info" wx:if="{{order}}">
    <!-- 场馆名称：通过 order.venue.name 获取关联的场馆名称 -->
    <text class="venue-name">{{order.venue.name}}</text>
    <!-- 预订日期和时段 -->
    <text class="order-time">{{order.book_date}} {{order.start_time}}-{{order.end_time}}</text>
  </view>

  <!-- ==================== 评价表单区域 ==================== -->
  <view class="review-form">

    <!-- ---------- 评分选择项 ---------- -->
    <view class="form-item">
      <text class="label">评分</text>
      <!--
        星级评分组件
        wx:for="{{[1,2,3,4,5]}}"：遍历数组 [1,2,3,4,5]，生成5颗星星
        - item 的值依次为 1、2、3、4、5

        class="star {{index < rating ? 'active' : ''}}"：
        动态添加 active 样式类名
        - index 是当前星星的序号（从0开始：0,1,2,3,4）
        - rating 是用户当前选择的评分值
        - 如果 index < rating，说明这颗星在评分范围内，添加 active 类（通常显示为黄色/高亮）
        - 否则不添加 active 类（通常显示为灰色）
        - 例如用户选了3分，则 index 为 0,1,2 的星星会高亮，3,4 的不会

        data-rating="{{item}}"：把当前星星代表的分值传递给点击事件
        bindtap="onRatingChange"：点击星星时触发评分变更函数
        例如点击第3颗星，item 值为3，函数会将 rating 设置为3
      -->
      <view class="rating">
        <text
          class="star {{index < rating ? 'active' : ''}}"
          wx:for="{{[1,2,3,4,5]}}"
          wx:key="index"
          data-rating="{{item}}"
          bindtap="onRatingChange">
          ★
        </text>
      </view>
    </view>

    <!-- ---------- 评价内容输入项 ---------- -->
    <view class="form-item">
      <text class="label">评价内容</text>
      <!--
        <textarea> 多行文本输入框
        - placeholder="请输入您的评价（选填）"：输入框为空时显示的灰色提示文字
        - maxlength="200"：最多允许输入200个字符
        - bindinput="onContentInput"：用户每次输入内容时触发 onContentInput 函数，
          实时更新评价内容变量
        - value="{{content}}"：输入框内容与 content 变量绑定
      -->
      <textarea
        class="textarea"
        placeholder="请输入您的评价（选填）"
        maxlength="200"
        bindinput="onContentInput"
        value="{{content}}">
      </textarea>
    </view>

    <!-- ==================== 提交评价按钮 ==================== -->
    <!--
      bindtap="submitReview"：点击按钮时执行 submitReview 函数
      该函数会将评分和评价内容提交到服务器保存
    -->
    <button class="submit-btn" bindtap="submitReview">提交评价</button>
  </view>
</view>
