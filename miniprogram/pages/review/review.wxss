.container {
  background: linear-gradient(180deg, #fff8f3 0%, #ffe8d6 100%);
  min-height: 100vh;
  padding: 30rpx;
}

.order-info {
  background: linear-gradient(135deg, #FF6B35 0%, #F77F00 100%);
  padding: 40rpx;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  text-align: center;
  box-shadow: 0 8rpx 30rpx rgba(255, 107, 53, 0.3);
}

.venue-name {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 15rpx;
}

.order-time {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.review-form {
  background: linear-gradient(135deg, #ffffff 0%, #fff5f0 100%);
  padding: 40rpx;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 25rpx rgba(255, 107, 53, 0.12);
  border-left: 6rpx solid #FF6B35;
}

.form-item {
  margin-bottom: 35rpx;
}

.label {
  display: block;
  font-size: 30rpx;
  color: #FF6B35;
  margin-bottom: 20rpx;
  font-weight: 600;
}

.rating {
  display: flex;
  justify-content: center;
  gap: 15rpx;
  padding: 20rpx 0;
}

.star {
  font-size: 70rpx;
  color: #e0e0e0;
  cursor: pointer;
  transition: all 0.3s ease;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.star.active {
  color: #FF6B35;
  text-shadow: 0 4rpx 15rpx rgba(255, 107, 53, 0.4);
  transform: scale(1.1);
}

.textarea {
  width: 100%;
  min-height: 220rpx;
  padding: 25rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 15rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background-color: #fff;
  transition: border-color 0.3s ease;
}

.textarea:focus {
  border-color: #FF6B35;
}

.submit-btn {
  width: 100%;
  height: 90rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #F77F00 100%);
  color: #fff;
  font-size: 32rpx;
  line-height: 90rpx;
  border-radius: 45rpx;
  margin-top: 40rpx;
  border: none;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 53, 0.3);
  font-weight: 500;
  transition: all 0.3s ease;
}

.submit-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 12rpx rgba(255, 107, 53, 0.2);
}
