/* 个人信息编辑页面样式文件 */

/* 页面容器 */
.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding: 20rpx;
}

/* 头像编辑区域 */
.avatar-section {
  display: flex;
  justify-content: center;
  margin: 40rpx 0;
}

.avatar-container {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid #f97316;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.avatar-upload-btn {
  position: absolute;
  bottom: 0;
  right: 0;
  background-color: rgba(0, 0, 0, 0.6);
  color: white;
  padding: 10rpx 15rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  font-size: 24rpx;
  cursor: pointer;
  transition: all 0.3s ease;
}

.avatar-upload-btn:hover {
  background-color: rgba(0, 0, 0, 0.8);
}

.upload-icon {
  margin-right: 5rpx;
  font-size: 28rpx;
}

/* 表单区域 */
.form-section {
  background-color: white;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 30rpx;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 25rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  width: 120rpx;
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.form-input {
  flex: 1;
  font-size: 32rpx;
  color: #333;
  padding: 10rpx 0;
}

.placeholder {
  color: #999;
}

.balance-text {
  font-size: 32rpx;
  color: #f97316;
  font-weight: bold;
}

/* 保存按钮 */
.save-btn {
  background: linear-gradient(135deg, #f97316 0%, #ff9500 100%);
  color: white;
  font-size: 34rpx;
  font-weight: bold;
  padding: 30rpx;
  border-radius: 20rpx;
  margin: 20rpx 0;
  box-shadow: 0 4rpx 12rpx rgba(249, 115, 22, 0.3);
  transition: all 0.3s ease;
}

.save-btn:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 16rpx rgba(249, 115, 22, 0.4);
}

.save-btn[disabled] {
  background: #ccc;
  box-shadow: none;
  transform: none;
}

/* 错误提示 */
.error-message {
  background-color: #fee2e2;
  color: #dc2626;
  padding: 20rpx;
  border-radius: 10rpx;
  margin-top: 20rpx;
  font-size: 28rpx;
  text-align: center;
  animation: fadeIn 0.3s ease;
}

/* 成功提示 */
.success-message {
  background-color: #dcfce7;
  color: #16a34a;
  padding: 20rpx;
  border-radius: 10rpx;
  margin-top: 20rpx;
  font-size: 28rpx;
  text-align: center;
  animation: fadeIn 0.3s ease;
}

/* 动画 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(-10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}