<!--
  搜索页面模板文件 (search.wxml)
  这是场馆搜索页面，用户可以通过输入关键词搜索篮球场馆。
  页面包含：搜索栏（输入框+搜索按钮）、搜索结果列表、加载和空状态提示。

  【本页面涉及的重要概念】
  - bindinput：输入框内容变化时触发的事件（用户每输入/删除一个字都会触发）
  - bindconfirm：用户在输入框按下键盘上的"搜索/确认"键时触发的事件
  - bindtap：用户点击某个元素时触发的事件
  - 多条件判断：wx:if 中使用 && (并且) 组合多个条件
-->

<!-- 页面最外层容器 -->
<view class="container">

  <!-- ==================== 搜索栏区域 ==================== -->
  <view class="search-bar">
    <!--
      <input> 搜索输入框
      - placeholder="搜索场地名称或位置"：输入框为空时显示的灰色提示文字，引导用户输入
      - value="{{keyword}}"：输入框的内容与 keyword 变量绑定，显示当前的搜索关键词
      - bindinput="onSearchInput"：用户每次输入内容时触发 onSearchInput 函数，
        实时更新 keyword 变量的值
      - bindconfirm="search"：用户按下键盘上的"搜索"键时，触发 search 函数执行搜索
    -->
    <input class="search-input" placeholder="搜索场地名称或位置" value="{{keyword}}" bindinput="onSearchInput" bindconfirm="search" />
    <!--
      搜索按钮：点击时触发 search 函数
      与键盘上的确认键功能相同，提供另一种触发搜索的方式
    -->
    <button class="search-btn" bindtap="search">搜索</button>
  </view>

  <!-- ==================== 搜索结果列表区域 ==================== -->
  <view class="result-list">
    <!--
      wx:for="{{venues}}"：遍历搜索结果数组，每个匹配的场馆生成一个卡片
      - item：当前遍历到的场馆数据
      - item.id：场馆的唯一标识
      bindtap="goToDetail"：点击场馆卡片跳转到场馆详情页
      data-id="{{item.id}}"：把场馆ID传递给点击事件函数，详情页根据此ID加载数据
    -->
    <view class="venue-item" wx:for="{{venues}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
      <!--
        场馆图片：显示图片数组中的第一张
        如果没有图片，使用随机占位图作为默认图片
        || 是"或"运算符：前面的值为空时使用后面的值
      -->
      <image class="venue-image" src="{{item.images[0] || 'https://picsum.photos/800/600?random=1'}}" mode="aspectFill" />
      <view class="venue-info">
        <!-- 场馆名称 -->
        <text class="venue-name">{{item.name}}</text>
        <!-- 场馆位置 -->
        <text class="venue-location">{{item.location}}</text>
      </view>
    </view>

    <!-- ==================== 列表状态提示 ==================== -->
    <!-- 搜索中提示：当 loading 为 true 时显示 -->
    <view class="loading" wx:if="{{loading}}">搜索中...</view>
    <!--
      空结果提示：同时满足以下三个条件时显示
      1. venues.length === 0：搜索结果为空（没有找到匹配的场馆）
      2. && !loading：当前不在搜索加载中（避免还在搜索时就显示"未找到"）
      3. && keyword：用户已经输入了搜索关键词（如果没输入关键词，不应该显示此提示）
    -->
    <view class="empty" wx:if="{{venues.length === 0 && !loading && keyword}}">未找到相关场地</view>
  </view>
</view>
