<!-- 个人信息编辑页面模板文件 -->

<!-- 页面最外层容器 -->
<view class="container">

  <!-- 头像编辑区域 -->
  <view class="avatar-section">
    <view class="avatar-container">
      <!-- 头像图片 -->
      <image class="avatar" src="{{userInfo.avatarUrl || 'data:image/svg+xml;base64,'}}" mode="aspectFill" />
      <!-- 上传按钮 -->
      <view class="avatar-upload-btn" bindtap="chooseAvatar">
        <text class="upload-icon">📷</text>
        <text class="upload-text">更换头像</text>
      </view>
    </view>
  </view>

  <!-- 个人信息表单区域 -->
  <view class="form-section">
    <!-- 用户名输入 -->
    <view class="form-item">
      <text class="form-label">用户名</text>
      <input 
        class="form-input" 
        value="{{userInfo.nickName}}" 
        bindinput="onNickNameChange" 
        placeholder="请输入用户名" 
        placeholder-class="placeholder"
        maxlength="20"
      />
    </view>

    <!-- 手机号输入 -->
    <view class="form-item">
      <text class="form-label">手机号</text>
      <input 
        class="form-input" 
        value="{{userInfo.phone}}" 
        bindinput="onPhoneChange" 
        placeholder="请输入手机号" 
        placeholder-class="placeholder"
        type="number"
        maxlength="11"
      />
    </view>

    <!-- 账户余额（只读） -->
    <view class="form-item">
      <text class="form-label">账户余额</text>
      <text class="balance-text">¥{{userInfo.balance.toFixed(2)}}</text>
    </view>
  </view>

  <!-- 保存按钮 -->
  <button class="save-btn" bindtap="saveProfile" disabled="{{isSaving}}">
    {{isSaving ? '保存中...' : '保存修改'}}
  </button>

  <!-- 错误提示 -->
  <view class="error-message" wx:if="{{errorMessage}}">
    {{errorMessage}}
  </view>

  <!-- 成功提示 -->
  <view class="success-message" wx:if="{{successMessage}}">
    {{successMessage}}
  </view>

</view>