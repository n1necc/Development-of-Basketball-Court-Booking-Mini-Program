.container {
  padding: 30rpx;
  background: linear-gradient(180deg, #fff8f3 0%, #ffe8d6 100%);
  min-height: 100vh;
}

.order-info {
  background: linear-gradient(135deg, #ffffff 0%, #fff5f0 100%);
  padding: 30rpx;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 25rpx rgba(255, 107, 53, 0.12);
  border-left: 6rpx solid #FF6B35;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #FF6B35;
  display: block;
  margin-bottom: 30rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}

.info-row.total {
  border-bottom: none;
  margin-top: 20rpx;
  padding-top: 30rpx;
  border-top: 2rpx solid #eee;
}

.label {
  font-size: 28rpx;
  color: #666;
}

.value {
  font-size: 28rpx;
  color: #333;
}

.value.price {
  font-size: 36rpx;
  color: #FF6B35;
  font-weight: bold;
}

.submit-btn {
  width: 100%;
  height: 90rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #F77F00 100%);
  color: #fff;
  font-size: 32rpx;
  line-height: 90rpx;
  border-radius: 20rpx;
  margin-top: 50rpx;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 53, 0.3);
}

.submit-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 12rpx rgba(255, 107, 53, 0.2);
}

.step-container {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.tip-text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
  text-align: center;
}

.qrcode-container {
  background: #fff;
  padding: 40rpx;
  border-radius: 20rpx;
  margin: 30rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.qrcode-image {
  width: 400rpx;
  height: 400rpx;
  margin-bottom: 20rpx;
}

.qrcode-tip {
  font-size: 26rpx;
  color: #999;
}
