.container {
  background: linear-gradient(180deg, #fff8f3 0%, #ffe8d6 100%);
  min-height: 100vh;
  padding: 20rpx;
}

.venue-item {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #ffffff 0%, #fff5f0 100%);
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  padding: 20rpx;
  box-shadow: 0 8rpx 25rpx rgba(255, 107, 53, 0.12);
  transition: all 0.3s ease;
  border-left: 6rpx solid #FF6B35;
}

.venue-item:active {
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 35rpx rgba(255, 107, 53, 0.2);
}

.venue-image {
  width: 150rpx;
  height: 150rpx;
  border-radius: 20rpx;
  margin-right: 20rpx;
  box-shadow: 0 4rpx 15rpx rgba(255, 107, 53, 0.15);
}

.venue-info {
  flex: 1;
}

.venue-name {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #FF6B35;
  margin-bottom: 10rpx;
}

.venue-location {
  font-size: 26rpx;
  color: #F77F00;
}

.remove-btn {
  padding: 12rpx 25rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #F77F00 100%);
  color: #fff;
  font-size: 24rpx;
  border-radius: 20rpx;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 53, 0.3);
}

.remove-btn:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(255, 107, 53, 0.2);
}

.empty, .loading {
  text-align: center;
  padding: 100rpx 0;
  color: #F77F00;
  font-size: 28rpx;
}
