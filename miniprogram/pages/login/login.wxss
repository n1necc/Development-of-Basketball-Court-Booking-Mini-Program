/* ==================== 登录页面容器 ==================== */
.container {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 100vh;
  background: linear-gradient(135deg, #FF6B35 0%, #F77F00 50%, #004E89 100%);
  position: relative;
  overflow: hidden;
}

/* 篮球纹理背景动画 */
.container::before {
  content: '';
  position: absolute;
  width: 200%;
  height: 200%;
  background-image:
    radial-gradient(circle at 20% 30%, rgba(255,255,255,0.15) 2px, transparent 2px),
    radial-gradient(circle at 60% 70%, rgba(255,255,255,0.1) 3px, transparent 3px),
    radial-gradient(circle at 80% 20%, rgba(255,255,255,0.12) 2px, transparent 2px);
  background-size: 80rpx 80rpx, 120rpx 120rpx, 100rpx 100rpx;
  animation: drift 25s linear infinite;
  opacity: 0.6;
}

/* 漂浮的篮球装饰 */
.container::after {
  content: '🏀';
  position: absolute;
  font-size: 120rpx;
  opacity: 0.1;
  top: 10%;
  right: 10%;
  animation: float 6s ease-in-out infinite;
}

@keyframes drift {
  from { transform: translate(0, 0) rotate(0deg); }
  to { transform: translate(50rpx, 50rpx) rotate(360deg); }
}

@keyframes float {
  0%, 100% {
    transform: translateY(0) rotate(0deg);
  }
  50% {
    transform: translateY(-30rpx) rotate(180deg);
  }
}

/* ==================== 登录框样式 ==================== */
.login-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 80rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
  border-radius: 40rpx;
  box-shadow: 0 30rpx 80rpx rgba(0, 0, 0, 0.25);
  position: relative;
  z-index: 1;
  animation: slideUp 0.6s ease-out;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(50rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ==================== Logo样式 ==================== */
.logo {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 50rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #F77F00 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 100rpx;
  box-shadow: 0 15rpx 40rpx rgba(255, 107, 53, 0.4);
  animation: bounce 2s ease-in-out infinite;
  position: relative;
}

.logo::after {
  content: '🏀';
  animation: spin 3s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

@keyframes bounce {
  0%, 100% {
    transform: translateY(0) scale(1);
  }
  50% {
    transform: translateY(-15rpx) scale(1.05);
  }
}

/* ==================== 标题样式 ==================== */
.title {
  font-size: 56rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #FF6B35 0%, #F77F00 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 20rpx;
  animation: fadeIn 0.8s ease-out 0.2s both;
}

.subtitle {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 80rpx;
  animation: fadeIn 0.8s ease-out 0.4s both;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ==================== 登录按钮样式 ==================== */
.login-btn {
  width: 520rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #F77F00 100%);
  color: #fff;
  font-size: 34rpx;
  line-height: 100rpx;
  border-radius: 50rpx;
  border: none;
  box-shadow: 0 10rpx 30rpx rgba(255, 107, 53, 0.4);
  font-weight: 600;
  position: relative;
  overflow: hidden;
  animation: fadeIn 0.8s ease-out 0.6s both;
}

.login-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
  transition: left 0.5s;
}

.login-btn:active {
  transform: scale(0.95);
  box-shadow: 0 5rpx 15rpx rgba(255, 107, 53, 0.3);
}

.login-btn:active::before {
  left: 100%;
}

/* ==================== 提示信息样式 ==================== */
.tips {
  margin-top: 40rpx;
  padding: 0 30rpx;
  animation: fadeIn 0.8s ease-out 0.8s both;
}

.tips text {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  display: block;
  line-height: 1.6;
}
