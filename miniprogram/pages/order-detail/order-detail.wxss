.container {
  background: linear-gradient(180deg, #fff8f3 0%, #ffe8d6 100%);
  min-height: 100vh;
  padding: 30rpx;
  padding-bottom: 60rpx;
  box-sizing: border-box;
}

.status-section {
  background: linear-gradient(135deg, #FF6B35 0%, #F77F00 100%);
  padding: 70rpx 30rpx;
  text-align: center;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(255, 107, 53, 0.3);
}

.status-icon {
  font-size: 120rpx;
  display: block;
  margin-bottom: 25rpx;
}

.status-text {
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
}

.qrcode-section {
  background: linear-gradient(135deg, #ffffff 0%, #fff5f0 100%);
  padding: 40rpx;
  text-align: center;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 25rpx rgba(255, 107, 53, 0.12);
  border-left: 6rpx solid #FF6B35;
  position: relative;
}

.qrcode {
  width: 400rpx;
  height: 400rpx;
  margin: 30rpx auto;
  border-radius: 15rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  display: block;
}

.qrcode-tip {
  font-size: 26rpx;
  color: #FF6B35;
  padding: 15rpx 20rpx;
  background: linear-gradient(135deg, #FFE8D6 0%, #FFF5F0 100%);
  border-radius: 10rpx;
  margin-top: 20rpx;
  border-left: 4rpx solid #FF6B35;
  display: inline-block;
  line-height: 1.5;
}

.info-section {
  background: linear-gradient(135deg, #ffffff 0%, #fff5f0 100%);
  padding: 35rpx;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 25rpx rgba(255, 107, 53, 0.12);
  border-left: 6rpx solid #FF6B35;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #FF6B35;
  display: block;
  margin-bottom: 30rpx;
  position: relative;
  padding-left: 20rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 30rpx;
  background: linear-gradient(180deg, #FF6B35 0%, #F77F00 100%);
  border-radius: 3rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 25rpx 0;
  border-bottom: 1rpx solid #ecf0f1;
}

.info-row:last-child {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  color: #7f8c8d;
  font-weight: 500;
}

.value {
  font-size: 28rpx;
  color: #2c3e50;
  text-align: right;
  max-width: 400rpx;
  font-weight: 500;
}

.value.price {
  font-size: 40rpx;
  color: #FF6B35;
  font-weight: bold;
}

.review-btn {
  width: 100%;
  height: 90rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #F77F00 100%);
  color: #fff;
  font-size: 32rpx;
  line-height: 90rpx;
  border-radius: 45rpx;
  border: none;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 53, 0.3);
  font-weight: 500;
  transition: all 0.3s ease;
}

.review-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 12rpx rgba(255, 107, 53, 0.2);
}

/* ==================== 订单操作按钮区域 ==================== */
.action-section {
  margin-bottom: 30rpx;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
  justify-content: space-between;
}

.action-btn {
  flex: 1;
  height: 90rpx;
  line-height: 90rpx;
  font-size: 32rpx;
  border-radius: 45rpx;
  border: none;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  font-weight: 500;
  transition: all 0.3s ease;
}

.action-btn.single {
  width: 100%;
}

.action-btn.cancel-btn {
  background: linear-gradient(135deg, #95a5a6 0%, #7f8c8d 100%);
  color: #fff;
}

.action-btn.confirm-btn {
  background: linear-gradient(135deg, #FF6B35 0%, #F77F00 100%);
  color: #fff;
}

.action-btn.pay-btn {
  background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);
  color: #fff;
}

.action-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.15);
}
