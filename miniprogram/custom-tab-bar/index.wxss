.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 110rpx;
  background: #ffffff;
  display: flex;
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  z-index: 999;
}

.tab-bar-border {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  height: 1rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(0, 0, 0, 0.05) 50%, transparent 100%);
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: all 0.3s ease;
}

.tab-bar-item:active {
  transform: scale(0.95);
}

.tab-icon {
  font-size: 40rpx;
  margin-bottom: 4rpx;
  transition: all 0.3s ease;
  opacity: 0.8;
}

.tab-bar-item:active .tab-icon {
  transform: scale(1.15);
  opacity: 1;
}

.tab-text {
  font-size: 22rpx;
  color: #8e8e93;
  font-weight: 500;
  transition: all 0.3s ease;
  letter-spacing: 0.5rpx;
}

.tab-bar-item:active .tab-text {
  color: #FF6B35;
  font-weight: 600;
}
