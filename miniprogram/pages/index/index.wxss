/* ==================== 页面容器 ==================== */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8f9fa 0%, #ffffff 100%);
}

/* ==================== Header 头部 ==================== */
.header {
  background: linear-gradient(135deg, #FF6B35 0%, #F77F00 100%);
  padding: 40rpx 30rpx;
  color: #fff;
  position: relative;
  overflow: hidden;
}

.header::before {
  content: '🏀';
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 80rpx;
  opacity: 0.2;
  animation: rotate 10s linear infinite;
}

@keyframes rotate {
  from { transform: translateY(-50%) rotate(0deg); }
  to { transform: translateY(-50%) rotate(360deg); }
}

.header-title {
  font-size: 44rpx;
  font-weight: bold;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

/* ==================== News Carousel 新闻轮播 ==================== */
.news-section {
  background-color: #fff;
  margin-bottom: 20rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  animation: fadeIn 0.6s ease-out;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.news-swiper {
  width: 100%;
  height: 420rpx;
}

.news-item {
  position: relative;
  width: 100%;
  height: 100%;
}

.news-image {
  width: 100%;
  height: 100%;
  transition: transform 0.3s ease;
}

.news-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
  padding: 50rpx 30rpx 30rpx;
}

.news-title {
  display: block;
  color: #fff;
  font-size: 34rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.3);
}

.news-summary {
  display: block;
  color: rgba(255,255,255,0.95);
  font-size: 26rpx;
  line-height: 1.5;
}

/* ==================== Quick Actions 快捷操作 ==================== */
.quick-actions {
  display: flex;
  background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
  padding: 40rpx 30rpx;
  margin-bottom: 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  animation: fadeIn 0.6s ease-out 0.2s both;
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: transform 0.3s ease;
}

.action-btn:active {
  transform: scale(0.9);
}

.action-icon {
  font-size: 70rpx;
  margin-bottom: 15rpx;
  filter: drop-shadow(0 4rpx 8rpx rgba(0,0,0,0.1));
  animation: bounce 2s ease-in-out infinite;
}

.action-btn:nth-child(1) .action-icon {
  animation-delay: 0s;
}

.action-btn:nth-child(2) .action-icon {
  animation-delay: 0.2s;
}

.action-btn:nth-child(3) .action-icon {
  animation-delay: 0.4s;
}

.action-btn:nth-child(4) .action-icon {
  animation-delay: 0.6s;
}

@keyframes bounce {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-8rpx);
  }
}

.action-text {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

/* ==================== Announcements 公告区域 ==================== */
.announcements-section {
  background-color: #fff;
  padding: 35rpx 30rpx;
  margin-bottom: 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  animation: fadeIn 0.6s ease-out 0.4s both;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #1a1a1a;
  display: flex;
  align-items: center;
}

.more-btn {
  font-size: 26rpx;
  color: #FF6B35;
  font-weight: 500;
}

.announcement-list {
  display: flex;
  flex-direction: column;
}

.announcement-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
  transition: all 0.3s ease;
  position: relative;
}

.announcement-item::before {
  content: '';
  position: absolute;
  left: -30rpx;
  top: 0;
  bottom: 0;
  width: 6rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #F77F00 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.announcement-item:active::before {
  opacity: 1;
}

.announcement-item:last-child {
  border-bottom: none;
}

.announcement-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.announcement-title {
  font-size: 30rpx;
  color: #1a1a1a;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.announcement-date {
  font-size: 24rpx;
  color: #999;
}

.announcement-arrow {
  font-size: 40rpx;
  color: #d1d5db;
  margin-left: 20rpx;
  transition: transform 0.3s ease;
}

.announcement-item:active .announcement-arrow {
  transform: translateX(5rpx);
}

/* ==================== Hot Venues 热门场馆 ==================== */
.hot-venues-section {
  background-color: #fff;
  padding: 35rpx 30rpx;
  margin-bottom: 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  animation: fadeIn 0.6s ease-out 0.6s both;
}

.venue-list {
  display: flex;
  flex-direction: column;
  gap: 25rpx;
}

.venue-card {
  display: flex;
  background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
  border-radius: 20rpx;
  overflow: hidden;
  border: 2rpx solid #f0f0f0;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
  transition: all 0.3s ease;
}

.venue-card:active {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.12);
}

.venue-card .venue-image {
  width: 240rpx;
  height: 200rpx;
  flex-shrink: 0;
  position: relative;
  overflow: hidden;
}

.venue-card .venue-image::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255,107,53,0.1) 0%, transparent 100%);
}

.venue-card .venue-info {
  flex: 1;
  padding: 25rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.venue-card .venue-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 10rpx;
}

.venue-card .venue-location {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.venue-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.venue-card .venue-price {
  font-size: 36rpx;
  color: #FF6B35;
  font-weight: bold;
}

.book-btn-small {
  padding: 12rpx 30rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #F77F00 100%);
  color: #fff;
  font-size: 26rpx;
  border-radius: 30rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 53, 0.3);
  transition: all 0.3s ease;
}

.book-btn-small:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 6rpx rgba(255, 107, 53, 0.2);
}
